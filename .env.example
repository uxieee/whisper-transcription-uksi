# Optional path override (default auto-detects ./venv/bin/python, then python3/python)
LOCAL_PYTHON_BIN=./venv/bin/python

# Local Whisper settings
LOCAL_WHISPER_MODEL=turbo
LOCAL_WHISPER_DEVICE=cpu

# API route limits
MAX_UPLOAD_MB=64
NEXT_PUBLIC_MAX_UPLOAD_MB=64

# Optional: local route handler timeout in milliseconds
LOCAL_TRANSCRIBE_TIMEOUT_MS=900000
